<?xml version="1.0" encoding="UTF-8"?>
<glyph name=".notdef" format="2">
  <advance width="{{ width }}"/>
  <outline>
    <contour>
      <point x="0" y="0" type="line"/>
      <point x="0" y="10" type="line"/>
      <point x="{{ weight }}" y="10" type="line"/>
      <point x="{{ weight }}" y="0" type="line"/>
    </contour>
  </outline>
</glyph>
